NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/realestate_crm
JWT_SECRET=dev-only-change-in-production-32chars
JWT_EXPIRES_IN=7d
# Comma-separated frontend URLs (no trailing slashes)
CORS_ORIGIN=http://localhost:5173,http://localhost:5175,https://crm.durgaproperty.com
# Slug of the organization whose inventory is shown on the public website
PUBLIC_ORGANIZATION_SLUG=durga-property
